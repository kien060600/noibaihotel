generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String
  createdAt DateTime @default(now())
}

model Booking {
  id           String   @id @default(cuid())
  guestName    String
  phone        String
  roomSlug     String
  checkInDate  String
  checkInTime  String
  checkOutDate String
  checkOutTime String
  guests       Int
  status       String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
